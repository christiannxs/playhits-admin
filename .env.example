# Supabase (obrigatório para o app)
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_ANON_KEY=sua_chave_anon_public

# Para "Sincronizar com Notion" no localhost: o Vite usa as variáveis acima
# para fazer proxy de /api/sync-notion para a Edge Function.
# Opcional: se usar outro nome no Vercel, pode usar VITE_SUPABASE_URL e VITE_SUPABASE_ANON_KEY.

# Gemini (se usar recursos que precisam da API)
# GEMINI_API_KEY=sua_chave
